{
  "name": "1040 Form Builder",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "christian-kohler.path-intellisense"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.preferences.importModuleSpecifier": "relative"
      }
    }
  },
  "initializeCommand": "mkdir -p ${localWorkspaceFolder}/output ${localWorkspaceFolder}/cache",
  "postCreateCommand": "npm install",
  "mounts": [
    "source=${localWorkspaceFolder}/output,target=/workspaces/1040_generator/output,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/cache,target=/workspaces/1040_generator/cache,type=bind,consistency=cached"
  ],
  "workspaceFolder": "/workspaces/1040_generator",
  "remoteUser": "node"
}
