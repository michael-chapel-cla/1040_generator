{
  "name": "1040-form-builder",
  "version": "1.0.0",
  "description": "Downloads IRS tax forms and fills them with randomized fake data",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "download": "ts-node scripts/download.ts",
    "analyze": "ts-node scripts/analyze.ts",
    "fill": "ts-node scripts/fill.ts",
    "fill:batch": "ts-node scripts/fill.ts --count 5"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "pdf-lib": "^1.17.1",
    "fs-extra": "^11.2.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
